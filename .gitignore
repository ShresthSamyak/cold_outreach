.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/
*.egg-info/

# --- IDE / tooling state ---
.vscode/
.idea/
*.swp
.claude/
