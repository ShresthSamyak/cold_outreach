# Apify
APIFY_TOKEN=
APIFY_LINKEDIN_ACTOR=             # profile-detail actor (e.g. apimaestro/linkedin-profile-detail)
APIFY_LINKEDIN_SEARCH_ACTOR=      # people-search actor (e.g. apimaestro/linkedin-people-search)
# APIFY_ACTOR_INPUT_KEY=profileUrls
# APIFY_SEARCH_INPUT_KEY=keywords

# Google Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=   # absolute path to service account JSON
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Local Chrome (for Playwright persistent context)
CHROME_USER_DATA_DIR=C:\Users\HP\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE_DIRECTORY=Default
CHROME_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe

# Assets
RESUME_PDF=C:\Users\HP\Documents\cold outreach\data\resume.pdf

# Sending behavior
MIN_SEND_DELAY_SECONDS=45
MAX_SEND_DELAY_SECONDS=180
DAILY_SEND_LIMIT=20
FOLLOWUP_DAYS=5
