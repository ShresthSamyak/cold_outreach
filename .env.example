# ===== Apify =====
APIFY_TOKEN=

# Profile-detail actor (takes URLs -> returns profile data).
# Example: apimaestro/linkedin-profile-detail
APIFY_LINKEDIN_ACTOR=

# People-search actor (takes keywords -> returns profile URLs).
# Example: apimaestro/linkedin-people-search
APIFY_LINKEDIN_SEARCH_ACTOR=

# Uncomment + override if your actor expects a different input field name.
# APIFY_ACTOR_INPUT_KEY=profileUrls
# APIFY_SEARCH_INPUT_KEY=keywords

# ===== Gemini =====
# google-genai SDK supports either API key OR Vertex AI auth.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Vertex AI fallback (only used if GEMINI_API_KEY is empty)
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# ===== Local Chrome (DEDICATED automation profile — separate from your main Chrome) =====
# Run `outreach setup` once to install ContactOut + log into LinkedIn + scan WhatsApp QR here.
CHROME_USER_DATA_DIR=C:\Users\HP\AppData\Local\outreach-chrome
CHROME_PROFILE_DIRECTORY=Default
CHROME_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe

# ===== Assets =====
RESUME_PDF=C:\Users\HP\Documents\cold outreach\data\resume.pdf

# ===== Sending behavior =====
MIN_SEND_DELAY_SECONDS=45
MAX_SEND_DELAY_SECONDS=180
DAILY_SEND_LIMIT=20
FOLLOWUP_DAYS=5
